{
  "name": "ai-web-dev-firm",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": ">=22.0.0 <23",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "audit:ci": "npm audit --omit=dev --audit-level=high",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "jest --coverage",
    "analyze": "ANALYZE=true next build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "node scripts/seed-ci.mjs",
    "ci:up": "docker compose -f compose.ci.yml up -d --wait",
    "ci:down": "docker compose -f compose.ci.yml down -v",
    "ci:preflight": "node scripts/preflight-test-env.mjs",
    "report:dup-emails": "node scripts/report-duplicate-emails.mjs",
    "retention": "node scripts/retention.mjs",
    "postinstall": "prisma generate",
    "ci:local": "bash scripts/ci-local.sh",
    "check:fast": "bash scripts/check-fast.sh",
    "release:prod": "bash scripts/release-local.sh",
    "smoke:prod": "bash scripts/smoke-production.sh",
    "backup": "bash scripts/backup.sh",
    "restore:drill": "bash scripts/restore-drill.sh"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "firebase": "^11.10.0",
    "framer-motion": "^12.7.4",
    "isomorphic-dompurify": "^2.26.0",
    "next": "^15.4.2",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^4.13.2",
    "prisma": "^6.19.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "server-only": "^0.0.1",
    "validator": "^13.15.15",
    "velite": "^0.3.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "nodemailer": "^9.0.3",
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/validator": "^13.15.2",
    "babel-jest": "^30.4.1",
    "eslint": "^9",
    "eslint-config-next": "^15.4.2",
    "jest": "^30.4.2",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
