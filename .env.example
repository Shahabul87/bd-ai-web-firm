# Copy this file to .env and fill in your actual values.

# Database (Prisma / Postgres)
DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public"

# Admin auth (Auth.js 5) — AUTH_SECRET must be >= 32 chars (validated in prod)
AUTH_SECRET="generate: openssl rand -base64 32"
AUTH_URL="https://www.craftsai.org"
ADMIN_EMAILS="you@example.com,teammate@example.com"

# Client portal auth — MUST be a DIFFERENT strong secret from AUTH_SECRET so the
# admin and portal login flows share no signing material. >= 32 chars.
PORTAL_AUTH_SECRET="generate: openssl rand -base64 32"

# notify-svc (all transactional email + push + auth) — server-only, never NEXT_PUBLIC
NOTIFY_URL="https://notify-api-production-2689.up.railway.app"
NOTIFY_API_KEY="craftsai_..."

# Recipient for new-lead alerts (optional; defaults to hello@craftsai.org)
CONTACT_EMAIL=hello@craftsai.org

# Distributed rate limiting (optional but RECOMMENDED for production/serverless).
# Without these, rate limits fall back to per-instance in-memory counters that do
# not hold across serverless instances or cold starts. Create a free Upstash
# Redis DB and paste its REST URL + token here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Observability sink (optional). When set, operational incidents (lead-persist
# failures, notify-svc failures, audit failures, rate-limiter errors) are POSTed
# here as JSON in addition to being logged. Point at Logtail/Axiom/Datadog/Slack.
OBSERVABILITY_WEBHOOK_URL=

# Google Analytics (optional — enables analytics + cookie-consent banner)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Push notifications (Firebase Cloud Messaging) — optional; set AFTER FCM setup
# (see docs/superpowers/specs/2026-07-05-push-notifications-design.md §8).
# All PUBLIC values (safe in the browser). The secret FCM service account lives
# ONLY in notify-svc, never here. Push stays fully disabled until all are set.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
